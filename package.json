{
  "name": "dispatch-app",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "bddgen": "bddgen",
    "test:e2e": "bddgen && playwright test",
    "test:e2e:ui": "bddgen && playwright test --ui",
    "test:e2e:debug": "bddgen && playwright test --debug",
    "test:e2e:pocketbase": "bddgen --config playwright.config.pocketbase.ts && playwright test --config playwright.config.pocketbase.ts",
    "test:e2e:serve": "concurrently --names \"emulator,nextjs\" --kill-others-on-fail \"npx firebase emulators:start --only auth,firestore --project demo-crowdcad\" \"cross-env NEXT_PUBLIC_USE_FIREBASE_EMULATOR=true NEXT_PUBLIC_USE_FIRESTORE_EMULATOR=true NEXT_PUBLIC_FIREBASE_API_KEY=fake-api-key NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=localhost NEXT_PUBLIC_FIREBASE_PROJECT_ID=demo-crowdcad NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=demo-crowdcad.appspot.com NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=000000000000 NEXT_PUBLIC_FIREBASE_APP_ID=1:000000000000:web:fake next dev\""
  },
  "dependencies": {
    "@heroui/react": "^2.8.5",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/postcss": "^4.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^11.10.0",
    "firebase-admin": "^13.8.0",
    "framer-motion": "^12.23.24",
    "lodash.isequal": "^4.5.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "next": "^15.5.7",
    "next-nprogress-bar": "^2.4.7",
    "nodemailer": "^7.0.5",
    "pocketbase": "^0.26.8",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-img-mapper": "^2.0.0",
    "react-resizable-panels": "^3.0.6",
    "react-toastify": "^11.0.5",
    "recharts": "^3.1.2",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.58.2",
    "@types/kill-port": "^2.0.3",
    "@types/lodash.isequal": "^4.5.8",
    "@types/node": "20.19.1",
    "@types/nodemailer": "^7.0.1",
    "@types/react": "19.1.8",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "daisyui": "^5.3.7",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "^15.5.7",
    "firebase-tools": "^15.8.0",
    "kill-port": "^2.0.1",
    "playwright-bdd": "^8.4.2",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "5.8.3",
    "wait-on": "^9.0.4"
  }
}
