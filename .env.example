# CrowdCAD example environment variables
# Copy this file to `.env.local` and fill values for your chosen backend.
# Do NOT commit your real `.env.local` with secrets.

# Backend selector: "firebase" (default) or "pocketbase"
NEXT_PUBLIC_BACKEND=firebase

# --- Firebase (used when NEXT_PUBLIC_BACKEND=firebase or unset) ---
NEXT_PUBLIC_FIREBASE_API_KEY=YOUR_API_KEY_HERE
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1234567890
NEXT_PUBLIC_FIREBASE_APP_ID=1:1234567890:web:abcdef123456
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXX  # optional

# --- PocketBase (used when NEXT_PUBLIC_BACKEND=pocketbase) ---
# See README.md "PocketBase (self-hosted / LAN)" for full setup steps.
NEXT_PUBLIC_POCKETBASE_URL=http://127.0.0.1:8090
# Used by scripts/setup-pocketbase.js only (not read by the app at runtime):
PB_URL=http://127.0.0.1:8090
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=YourPassword!

# Recommended for deployments that may handle PHI to avoid telemetry leakage
DISABLE_TELEMETRY=true
